{
    "target": {
        "url": "http://localhost:8002/",
        "follow_redirects": true,
        "max_redirects": 5,
        "timeout": 10,
        "verify_ssl": false
    },
    "headers": {
        "enabled": true,
        "checks": [
            "X-Frame-Options",
            "Content-Security-Policy",
            "X-Content-Type-Options",
            "Strict-Transport-Security",
            "Referrer-Policy",
            "X-XSS-Protection"
        ]
    },
    "forms": {
        "enabled": true,
        "csrf_field_names": [
            "_token",
            "csrf_token",
            "csrfmiddlewaretoken",
            "authenticity_token"
        ]
    },
    "ports": {
        "enabled": true,
        "timeout": 5,
        "list": [
            80,
            443,
            8080,
            8443,
            3306,
            5432,
            6379,
            22,
            21
        ]
    },
    "output": {
        "json": "report.json",
        "html": null
    }
}